          <div class="exp-caption">
            <div class="exp-caption-label">Point Barrow</div>
            <div class="exp-caption-title">The Arctic Ocean</div>
          </div>
        </a>

        <div class="exp-item">
          <img src={whaleboneImg} alt="Historic Whalebone Arch silhouetted against a vivid Arctic sunset in Utqiaġvik, Alaska — a stop on the Kiita Tours cultural city tour" class="exp-img" />
          <div class="exp-overlay" aria-hidden="true"></div>
          <div class="exp-caption">
            <div class="exp-caption-label">Cultural Landmark</div>
            <div class="exp-caption-title">Whalebone Arch</div>
