    /* ── Responsive ──────────────────────────────── */
    @media (min-width: 600px) {
      .trust-grid   { grid-template-columns: repeat(2, 1fr); }
      .tours-grid   { grid-template-columns: 1fr 1fr; }
    }
    @media (min-width: 900px) {
      .trust-grid   { grid-template-columns: repeat(4, 1fr); }
      .tours-grid   { grid-template-columns: repeat(2, 1fr); }
      .guide-grid   { grid-template-columns: 380px 1fr; gap: 5rem; }
      .exp-item:first-child { grid-column: span 1; }
      .exp-grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      }
      .exp-item:first-child .exp-img,
      .exp-item:not(:first-child) .exp-img { height: 24rem; }
    }
    @media (max-width: 599px) {
      .nav-links { display: none; }
      .hero-content { padding-bottom: 3.5rem; }
      .trust { padding: 4rem 0; }
      .tours { padding: 4.5rem 0; }
      .guide { padding: 4.5rem 0; }
      .experience { padding: 4.5rem 0; }
      .booking { padding: 4.5rem 0; }
      .guide-credential { right: 0.5rem; bottom: -1rem; }
    }

    /* ── Aurora animation ────────────────────────── */
    @keyframes aurora {
      from { background-position: 50% 50%, 50% 50%; }
      to   { background-position: 350% 50%, 350% 50%; }
    }

    .aurora-layer {
      position: absolute;
      inset: -10px;
      z-index: 1;
      pointer-events: none;
      overflow: hidden;
      /* Colors sampled from the updated whalebone arch sunset photo:
         cool Arctic steel blue → pale sun gold → warm amber → deeper golden-orange */
      background-image:
        repeating-linear-gradient(
          100deg,
          #081320 0%, #081320 7%,
          transparent 10%, transparent 12%,
          #081320 16%
        ),
        repeating-linear-gradient(
          100deg,
          #1a3a5c 10%,
          #fde68a 15%,
          #4a7a96 20%,
          #f5c14a 25%,
          #6a9ab0 30%,
          #e8a832 35%,
          #1a3a5c 40%
        );
      background-size: 300%, 200%;
      background-position: 50% 50%, 50% 50%;
      filter: blur(10px);
      opacity: 0.5;
      animation: aurora 60s linear infinite;
      will-change: background-position;
      -webkit-mask-image: radial-gradient(ellipse at 100% 0%, black 10%, transparent 70%);
      mask-image: radial-gradient(ellipse at 100% 0%, black 10%, transparent 70%);
    }

    .aurora-layer::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        repeating-linear-gradient(
          100deg,
          #081320 0%, #081320 7%,
          transparent 10%, transparent 12%,
          #081320 16%
        ),
        repeating-linear-gradient(
          100deg,
          #1a3a5c 10%,
          #fde68a 15%,
          #4a7a96 20%,
          #f5c14a 25%,
          #6a9ab0 30%,
          #e8a832 35%,
          #1a3a5c 40%
        );
      background-size: 200%, 100%;
      background-attachment: fixed;
      mix-blend-mode: difference;
      animation: aurora 60s linear infinite;
    }

    /* ── Mobile: suppress aurora to avoid Android Chromium GPU glitches ── */
    /* All five known-bad properties (filter+blur, mask-image, will-change,
       background-attachment:fixed, mix-blend-mode) are inside .aurora-layer
       and its ::after. On touch/coarse-pointer devices we hide them entirely
       and replace with a simple static warm glow on hero-overlay-2. */
    @media (pointer: coarse) {
      .aurora-layer,
      .aurora-layer::after {
        display: none;
      }
      .hero-overlay-2 {
        background:
          radial-gradient(ellipse at 75% 38%, rgba(245,193,74,0.13) 0%, transparent 52%),
          radial-gradient(ellipse at 55% 40%, rgba(78,205,196,0.05) 0%, transparent 55%);
      }
    }

    /* ── Practical info strip ────────────────────── */
    .practical-strip {
      margin-top: 2.5rem;
      background: #fff;
      border-radius: 1.25rem;
      padding: 2rem 2rem 1.75rem;
      box-shadow: 0 2px 12px rgba(13,27,42,0.06), 0 1px 3px rgba(13,27,42,0.04);
    }
    .practical-strip-label {
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--teal);
      margin-bottom: 1.5rem;
    }
    .practical-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .practical-col h4 {
      font-family: var(--r-serif);
      font-size: 0.9375rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 0.75rem;
      letter-spacing: -0.01em;
    }
    .practical-col p {
      font-size: 0.8375rem;
      color: rgba(26,26,46,0.65);
      line-height: 1.7;
    }
    .practical-col ul {
      font-size: 0.8375rem;
      color: rgba(26,26,46,0.65);
      line-height: 1.7;
      padding-left: 1.125rem;
      margin-top: 0.25rem;
    }
    .practical-col ul li { margin-bottom: 0.2rem; }
    .season-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }
    .season-item {
      background: rgba(78,205,196,0.07);
      border-radius: 0.625rem;
      padding: 0.625rem 0.75rem;
    }
    .season-name {
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--teal);
      margin-bottom: 0.2rem;
    }
    .season-temp {
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--navy);
      line-height: 1.3;
    }
    .season-note {
      font-size: 0.7rem;
      color: rgba(26,26,46,0.45);
      margin-top: 0.15rem;
    }
    @media (min-width: 700px) {
      .practical-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (min-width: 900px) {
      .practical-grid { grid-template-columns: 1fr 1fr 1fr; }
    }

    /* ── Section CTA row ─────────────────────────── */
    .section-cta-row {
      margin-top: 2.5rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 1.25rem;
      padding: 1.375rem 1.75rem;
      border-radius: 1rem;
    }
    .section-cta-row.on-light {
      background: rgba(78,205,196,0.07);
      border: 1px solid rgba(78,205,196,0.16);
    }
    .section-cta-row.on-dark {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
    }
    .section-cta-row p {
      font-size: 0.9375rem;
      line-height: 1.55;
      margin: 0;
    }
    .section-cta-row.on-light p { color: rgba(26,26,46,0.7); }
    .section-cta-row.on-dark  p { color: rgba(245,245,240,0.6); }
    .section-cta-row.on-light strong { color: var(--navy); }
    .section-cta-row.on-dark  strong { color: var(--ice); }

    /* ── Tour urgency + private featured ─────────── */
    .tour-urgency {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.6875rem;
      font-weight: 600;
      color: #c4712a;
      background: rgba(244,162,97,0.12);
      padding: 0.2rem 0.55rem;
      border-radius: 9999px;
      margin-left: 0.5rem;
      vertical-align: middle;
    }
    .tour-urgency-dot {
      width: 5px;
      height: 5px;
      background: #f4a261;
      border-radius: 50%;
      flex-shrink: 0;
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.4; }
    }
    .tour-card.tour-featured {
      border: 1.5px solid rgba(244,162,97,0.3);
      box-shadow:
        0 4px 24px rgba(0,0,0,0.2),
        0 1px 4px rgba(0,0,0,0.12),
        inset 0 0 0 1px rgba(244,162,97,0.08);
    }
    .private-note {
      font-size: 0.8rem;
      color: rgba(26,26,46,0.52);
      margin-top: 0.5rem;
      font-style: italic;
    }

    /* ── On the Tour photo strip ─────────────────── */
    .on-the-tour {
      background: var(--navy);
      padding: 5rem 0;
    }
    .on-the-tour-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .on-the-tour-header .label { margin-bottom: 0.625rem; }
    .on-the-tour-header h2 {
      font-family: var(--font-head);
      font-size: clamp(1.5rem, 3vw, 2.125rem);
      color: var(--ice);
      letter-spacing: -0.03em;
      margin: 0;
    }
    .tour-photos-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    @media (max-width: 599px) {
      .tour-photos-grid { grid-template-columns: 1fr; }
    }
    .tour-photo-card {
      position: relative;
      border-radius: 1rem;
      overflow: hidden;
    }
    .tour-photo-card img {
      width: 100%;
      height: 26rem;
      object-fit: cover;
      object-position: center;
      display: block;
      transition: transform 0.6s ease;
    }
    @media (max-width: 599px) {
      .tour-photo-card img { height: 20rem; }
    }
    .tour-photo-card:hover img { transform: scale(1.03); }
    .tour-photo-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13,27,42,0.88) 0%, rgba(13,27,42,0.4) 40%, rgba(13,27,42,0.05) 70%, transparent 100%);
      pointer-events: none;
    }
    .tour-photo-card-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1.25rem 1.5rem;
    }
    .tour-photo-card-caption-label {
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 0.3rem;
    }
    .tour-photo-card-caption-title {
      font-family: var(--font-head);
      font-size: 1.0625rem;
      color: var(--ice);
      letter-spacing: -0.02em;
      line-height: 1.35;
      margin-bottom: 0.4rem;
    }
    .tour-photo-card-caption-body {
      font-family: var(--font-body);
      font-size: 0.8125rem;
      color: rgba(245,245,240,0.68);
      line-height: 1.6;
    }
    .on-the-tour-intro {
      font-family: var(--font-body);
      font-size: 1rem;
      color: rgba(245,245,240,0.62);
      line-height: 1.7;
      text-align: center;
      max-width: 52ch;
      margin: 0.5rem auto 2.25rem;
    }

    /* ── Reviews placeholder section ─────────────── */
    .reviews {
      background: var(--ice);
      padding: 5.5rem 0;
    }
    .reviews-header {
      margin-bottom: 2.5rem;
      text-align: center;
    }
    .reviews-header .label { margin-bottom: 0.75rem; }
    .reviews-card {
      background: #fff;
      border-radius: 1.375rem;
      padding: 2.75rem 2rem;
      max-width: 42rem;
      margin: 0 auto;
      text-align: center;
      box-shadow: 0 2px 16px rgba(13,27,42,0.07), 0 1px 4px rgba(13,27,42,0.04);
    }
    .reviews-stars {
      display: flex;
      justify-content: center;
      gap: 0.3rem;
      margin-bottom: 1.125rem;
    }
    .reviews-stars svg { color: #f4a261; }
    .reviews-card h3 {
      font-family: var(--r-serif);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 0.75rem;
      letter-spacing: -0.02em;
    }
    .reviews-card p {
      font-size: 0.9375rem;
      color: rgba(26,26,46,0.6);
      line-height: 1.72;
      max-width: 34ch;
      margin: 0 auto 1.875rem;
    }
    .btn-reviews {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: #fff;
      border: 1.5px solid rgba(13,27,42,0.14);
      color: var(--ink);
      font-family: var(--r-sans);
      font-size: 0.875rem;
      font-weight: 600;
      padding: 0.8125rem 1.625rem;
      border-radius: 9999px;
      cursor: pointer;
      transition: transform 0.2s var(--ease-spring), box-shadow 0.2s ease;
    }
    .btn-reviews:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(13,27,42,0.12);
    }

    /* ── Map panel ───────────────────────────────── */
    .map-panel {
      margin-top: 0.875rem;
      border-radius: 1rem;
      overflow: hidden;
      display: grid;
      grid-template-columns: 1fr;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      box-shadow: 0 4px 24px rgba(0,0,0,0.3);
    }
    .map-panel-img {
      position: relative;
      overflow: hidden;
      background: #0a1e32;
    }
    .map-panel-img img {
      width: 100%;
      height: 22rem;
      object-fit: contain;
      object-position: center;
      display: block;
      padding: 1.5rem;
    }
    .map-panel-text {
      padding: 2rem 2rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .map-panel-text .exp-caption-label { margin-bottom: 0.5rem; }
    .map-panel-text .exp-caption-title { font-size: 1.25rem; margin-bottom: 0.875rem; }
    .map-panel-text p {
      font-size: 0.875rem;
      color: rgba(245,245,240,0.65);
      line-height: 1.78;
    }
    @media (min-width: 700px) {
      .map-panel { grid-template-columns: 1fr 1fr; }
      .map-panel-img img { height: 100%; min-height: 20rem; }
    }

    /* ── Live webcam badge ───────────────────────── */
    .webcam-badge {
      position: absolute;
      top: 0.875rem;
      right: 0.875rem;
      z-index: 4;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: rgba(8, 19, 32, 0.72);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid rgba(78, 205, 196, 0.3);
      border-radius: 9999px;
      padding: 0.35rem 0.75rem 0.35rem 0.55rem;
      font-family: var(--r-sans);
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: rgba(245, 245, 240, 0.9);
      text-transform: uppercase;
      pointer-events: none;
      transition: background 0.2s ease, border-color 0.2s ease;
    }
    a.exp-item:hover .webcam-badge {
      background: rgba(78, 205, 196, 0.18);
      border-color: rgba(78, 205, 196, 0.6);
    }
    a.exp-item:focus-visible {
      outline: 2px solid var(--teal);
      outline-offset: 3px;
    }
    .webcam-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #4ecdc4;
      flex-shrink: 0;
      animation: live-pulse 2s ease-in-out infinite;
    }
    @keyframes live-pulse {
      0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(78, 205, 196, 0.5); }
      50%       { opacity: 0.7; box-shadow: 0 0 0 4px rgba(78, 205, 196, 0); }
    }

    /* ── Guide CTA link ──────────────────────────── */
    .guide-facebook-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1.75rem;
      color: rgba(26,26,46,0.55);
      font-size: 0.875rem;
      font-weight: 500;
      transition: color 0.2s ease;
    }
    .guide-facebook-link:hover { color: var(--navy); }
  </style>
</head>
