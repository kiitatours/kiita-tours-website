    /* ── Footer ──────────────────────────────────── */
    .footer {
      background: var(--navy-d);
      padding: 2.75rem 0;
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    .footer-inner {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }
    .footer-brand {
      display: flex;
      align-items: center;
      gap: 0.625rem;
    }
    .footer-brand img {
      height: 1.875rem;
      width: 1.875rem;
      object-fit: contain;
      opacity: 0.65;
    }
    .footer-brand-name {
      font-family: var(--r-serif);
      font-size: 0.9375rem;
      font-weight: 600;
      color: rgba(245,245,240,0.6);
