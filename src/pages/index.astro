    /* ── Experience ──────────────────────────────── */
    .experience {
      background: var(--navy-d);
      padding: 6rem 0;
      position: relative;
      overflow: hidden;
    }
    .experience-header {
      margin-bottom: 3rem;
    }
    .experience-header .label { margin-bottom: 0.75rem; }
    .experience-header .h2 { color: var(--ice); }
    .exp-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.875rem;
    }
    .exp-item {
      position: relative;
      border-radius: 1rem;
      overflow: hidden;
      cursor: default;
      display: block;
      text-decoration: none;
    }
    a.exp-item { cursor: pointer; }
    .exp-item:first-child {
      grid-column: span 2;
