      width: 100%;
      height: 20rem;
      object-fit: cover;
      display: block;
      transition: transform 0.6s ease;
    }
    .museum-row:hover .museum-img-wrap img { transform: scale(1.03); }
    .museum-img-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(8,19,32,0.6) 0%, transparent 60%);
