      color: var(--teal);
      margin-bottom: 0.25rem;
    }
    .exp-caption-title {
      font-family: var(--r-serif);
      font-size: 1.0625rem;
      font-weight: 700;
      color: var(--ice);
      letter-spacing: -0.01em;
      line-height: 1.25;
