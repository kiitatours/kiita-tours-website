      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 1.25rem 1.25rem 1.125rem;
    }
    .exp-caption-label {
      font-size: 0.6375rem;
      font-weight: 600;
      text-transform: uppercase;
