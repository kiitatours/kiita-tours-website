      </a>
      <nav class="nav-links" aria-label="Primary navigation">
        <a href="/#tours"             class="nav-link active">Tours</a>
        <a href="/#guide"             class="nav-link">About</a>
        <a href="/#experience"        class="nav-link">Experience</a>
        <a href="/safety-preparation" class="nav-link">Prepare</a>
        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLSfawe488EpOrNJvKYm32IzR_UjjyO5BpFTBiQbeg3J3qJ9t8g/viewform?usp=header"
