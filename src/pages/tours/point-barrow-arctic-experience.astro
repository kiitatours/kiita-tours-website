          class="btn btn-teal btn-cta-primary"
          onclick="gtag('event', 'book_click', {source: 'hero_point_barrow'})"
        >
          Book This Tour
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#experience" class="btn btn-ghost-light">See What's Included</a>
      </div>
    </div>
