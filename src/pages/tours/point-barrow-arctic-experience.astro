          <span class="snapshot-sub">Weekends 9 AM–7 PM</span>
        </div>
      </div>
      <div class="snapshot-actions">
        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLSfawe488EpOrNJvKYm32IzR_UjjyO5BpFTBiQbeg3J3qJ9t8g/viewform?usp=header"
          target="_blank" rel="noopener noreferrer"
          class="btn btn-teal"
          onclick="gtag('event', 'book_click', {source: 'snapshot_point_barrow'})"
        >
          Reserve Your Spot
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
