  <!-- ══════════════════════ HERO ══════════════════════ -->
  <section class="page-hero grain" aria-label="Page header">
    <div class="page-hero-media" aria-hidden="true">
      <img src={heroImg} alt="" fetchpriority="high" />
    </div>
    <div class="page-hero-overlay" aria-hidden="true"></div>

    <div class="wrap page-hero-content">
      <nav class="page-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Kiita Tours</a>
        <span class="page-breadcrumb-sep" aria-hidden="true">›</span>
        <a href="/#tours">Tours</a>
        <span class="page-breadcrumb-sep" aria-hidden="true">›</span>
        <span aria-current="page">Point Barrow Arctic Experience</span>
      </nav>

      <p class="label label-teal">Group Tour · Utqiaġvik, Alaska</p>

      <h1 class="display page-hero-title">
        Point Barrow<br />Arctic Experience<br />
        <em>Stand at the Top<br />of America.</em>
      </h1>

      <p class="page-hero-sub">
        A guided tour to the northernmost point in the United States — 71.38°N latitude,
        where the Arctic Ocean, Beaufort Sea, and Chukchi Sea converge.
        Led by Robin Mongoyak, a lifelong Iñupiat guide born and raised in Utqiaġvik (Barrow), Alaska.
      </p>

      <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLSfawe488EpOrNJvKYm32IzR_UjjyO5BpFTBiQbeg3J3qJ9t8g/viewform?usp=header"
